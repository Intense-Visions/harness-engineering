# Required: secret shared with the harness orchestrator's webhook subscription.
# Opaque base64url string (~44 chars) from the POST /api/v1/webhooks response.
# Treat as a one-time secret — capture once, store securely, never log.
# Bridges that lose this value MUST delete + recreate the subscription.
HARNESS_WEBHOOK_SECRET=replace-me-with-secret-from-orchestrator-response

# Required: Slack bot token with chat:write scope.
# https://api.slack.com/authentication/token-types#bot
SLACK_BOT_TOKEN=xoxb-replace-me

# Required: Slack channel ID (NOT name — find via channel details → "About").
SLACK_CHANNEL=C0000000000

# Optional: HTTP port the bridge listens on. Default: 3000.
PORT=3000

# Optional: HTTP bind address. Default: 127.0.0.1.
# Override to 0.0.0.0 only when the bridge MUST accept off-host connections directly
# (otherwise prefer a tunnel — see README "Exposing the bridge to the internet").
HOST=127.0.0.1
