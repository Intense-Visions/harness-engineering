{
  "version": 1,
  "name": "harness-engineering",
  "layers": [
    {
      "name": "types",
      "pattern": "packages/types/src/**",
      "allowedDependencies": []
    },
    {
      "name": "graph",
      "pattern": "packages/graph/src/**",
      "allowedDependencies": ["types"]
    },
    {
      "name": "core",
      "pattern": "packages/core/src/**",
      "allowedDependencies": ["types", "graph"]
    },
    {
      "name": "eslint-plugin",
      "pattern": "packages/eslint-plugin/src/**",
      "allowedDependencies": ["types", "core"]
    },
    {
      "name": "linter-gen",
      "pattern": "packages/linter-gen/src/**",
      "allowedDependencies": ["types", "core"]
    },
    {
      "name": "orchestrator",
      "pattern": "packages/orchestrator/src/**",
      "allowedDependencies": ["types", "core"]
    },
    {
      "name": "cli",
      "pattern": "packages/cli/src/**",
      "allowedDependencies": ["types", "core", "graph", "linter-gen", "orchestrator"]
    }
  ],
  "forbiddenImports": [
    {
      "from": "packages/types/src/**",
      "disallow": [
        "packages/core/src/**",
        "packages/graph/src/**",
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/orchestrator/src/**",
        "packages/cli/src/**"
      ],
      "message": "Types layer cannot import from higher layers"
    },
    {
      "from": "packages/graph/src/**",
      "disallow": [
        "packages/core/src/**",
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/orchestrator/src/**",
        "packages/cli/src/**"
      ],
      "message": "Graph layer cannot import from higher layers"
    },
    {
      "from": "packages/core/src/**",
      "disallow": [
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/orchestrator/src/**",
        "packages/cli/src/**"
      ],
      "message": "Core layer cannot import from higher layers"
    },
    {
      "from": "packages/eslint-plugin/src/**",
      "disallow": ["packages/orchestrator/src/**", "packages/cli/src/**"],
      "message": "ESLint plugin cannot import from orchestrator or CLI"
    },
    {
      "from": "packages/linter-gen/src/**",
      "disallow": ["packages/orchestrator/src/**", "packages/cli/src/**"],
      "message": "Linter gen cannot import from orchestrator or CLI"
    },
    {
      "from": "packages/orchestrator/src/**",
      "disallow": ["packages/cli/src/**"],
      "message": "Orchestrator cannot import from CLI"
    }
  ],
  "boundaries": {
    "requireSchema": ["packages/cli/src/mcp/**"]
  },
  "architecture": {
    "enabled": true,
    "baselinePath": ".harness/arch/baselines.json",
    "thresholds": {
      "circular-deps": { "max": 0 },
      "layer-violations": { "max": 0 },
      "complexity": { "max": 15 },
      "coupling": { "maxFanIn": 10, "maxFanOut": 8 },
      "forbidden-imports": { "max": 0 },
      "module-size": { "maxFiles": 30, "maxLoc": 3500 },
      "dependency-depth": { "max": 7 }
    },
    "modules": {}
  },
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "agent": {
    "executor": "subprocess",
    "timeout": 300000
  },
  "security": {
    "enabled": true,
    "strict": false,
    "rules": {
      "SEC-CRY-001": "warning"
    },
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/*.test.ts",
      "**/tests/fixtures/**",
      "**/coverage/**",
      "**/security/rules/**"
    ]
  },
  "entropy": {
    "excludePatterns": ["**/node_modules/**", "**/dist/**", "**/*.test.ts", "**/tests/fixtures/**"],
    "autoFix": false
  },
  "performance": {
    "entryPoints": [
      "packages/types/src/index.ts",
      "packages/core/src/index.ts",
      "packages/graph/src/index.ts",
      "packages/cli/src/index.ts",
      "packages/cli/src/bin/harness.ts",
      "packages/eslint-plugin/src/index.ts",
      "packages/linter-gen/src/index.ts",
      "packages/orchestrator/src/index.ts"
    ],
    "complexity": {
      "enabled": true,
      "thresholds": {
        "cyclomaticComplexity": { "error": 15, "warn": 10 },
        "nestingDepth": { "warn": 4 },
        "functionLength": { "warn": 50 },
        "parameterCount": { "warn": 5 },
        "fileLength": { "info": 300 },
        "hotspotPercentile": { "error": 95 }
      }
    },
    "coupling": {
      "enabled": true,
      "thresholds": {
        "fanOut": { "warn": 15 },
        "fanIn": { "info": 20 },
        "couplingRatio": { "warn": 0.7 },
        "transitiveDependencyDepth": { "info": 30 }
      }
    },
    "sizeBudget": {
      "enabled": false,
      "budgets": {}
    }
  },
  "template": {
    "level": "advanced",
    "version": 1
  }
}
