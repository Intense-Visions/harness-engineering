{
  "version": 1,
  "name": "harness-engineering",
  "layers": [
    {
      "name": "types",
      "pattern": "packages/types/src/**",
      "allowedDependencies": []
    },
    {
      "name": "graph",
      "pattern": "packages/graph/src/**",
      "allowedDependencies": ["types"]
    },
    {
      "name": "core",
      "pattern": "packages/core/src/**",
      "allowedDependencies": ["types"]
    },
    {
      "name": "eslint-plugin",
      "pattern": "packages/eslint-plugin/src/**",
      "allowedDependencies": ["types", "core"]
    },
    {
      "name": "linter-gen",
      "pattern": "packages/linter-gen/src/**",
      "allowedDependencies": ["types", "core"]
    },
    {
      "name": "cli",
      "pattern": "packages/cli/src/**",
      "allowedDependencies": ["types", "core", "graph"]
    },
    {
      "name": "mcp-server",
      "pattern": "packages/mcp-server/src/**",
      "allowedDependencies": ["types", "core", "graph", "cli"]
    }
  ],
  "forbiddenImports": [
    {
      "from": "packages/types/src/**",
      "disallow": [
        "packages/core/src/**",
        "packages/graph/src/**",
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/cli/src/**",
        "packages/mcp-server/src/**"
      ],
      "message": "Types layer cannot import from higher layers"
    },
    {
      "from": "packages/core/src/**",
      "disallow": [
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/cli/src/**",
        "packages/mcp-server/src/**"
      ],
      "message": "Core layer cannot import from higher layers"
    },
    {
      "from": "packages/graph/src/**",
      "disallow": [
        "packages/eslint-plugin/src/**",
        "packages/linter-gen/src/**",
        "packages/cli/src/**",
        "packages/mcp-server/src/**"
      ],
      "message": "Graph layer cannot import from higher layers"
    },
    {
      "from": "packages/eslint-plugin/src/**",
      "disallow": ["packages/cli/src/**", "packages/mcp-server/src/**"],
      "message": "ESLint plugin cannot import from CLI or MCP server"
    },
    {
      "from": "packages/linter-gen/src/**",
      "disallow": ["packages/cli/src/**", "packages/mcp-server/src/**"],
      "message": "Linter gen cannot import from CLI or MCP server"
    },
    {
      "from": "packages/cli/src/**",
      "disallow": ["packages/mcp-server/src/**"],
      "message": "CLI cannot import from MCP server"
    }
  ],
  "boundaries": {
    "requireSchema": ["packages/mcp-server/**"]
  },
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "agent": {
    "executor": "subprocess",
    "timeout": 300000
  },
  "security": {
    "enabled": true,
    "strict": false,
    "exclude": ["**/node_modules/**", "**/dist/**", "**/*.test.ts", "**/tests/fixtures/**"]
  },
  "entropy": {
    "excludePatterns": ["**/node_modules/**", "**/dist/**", "**/*.test.ts", "**/tests/fixtures/**"],
    "autoFix": false
  },
  "template": {
    "level": "advanced",
    "version": 1
  }
}
