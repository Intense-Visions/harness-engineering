{
  "name": "@harness-engineering/cli",
  "version": "1.6.2",
  "description": "CLI for Harness Engineering toolkit",
  "type": "module",
  "bin": {
    "harness": "./dist/bin/harness.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && cp -r ../../templates dist/templates && cp -r ../../agents dist/agents",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "handlebars": "^4.7.0",
    "lokijs": "^1.5.12",
    "minimatch": "^10.2.4",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@harness-engineering/core": "workspace:*",
    "@harness-engineering/graph": "workspace:*",
    "@harness-engineering/linter-gen": "workspace:*",
    "@harness-engineering/types": "workspace:*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Intense-Visions/harness-engineering.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Intense-Visions/harness-engineering/issues"
  },
  "homepage": "https://github.com/Intense-Visions/harness-engineering/tree/main/packages/cli#readme"
}
