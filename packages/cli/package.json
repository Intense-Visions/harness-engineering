{
  "name": "@harness-engineering/cli",
  "version": "1.0.0",
  "description": "CLI for Harness Engineering toolkit",
  "type": "module",
  "bin": {
    "harness": "./dist/bin/harness.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin/harness.ts --format esm --dts --outDir dist",
    "dev": "tsup src/index.ts src/bin/harness.ts --format esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@harness-engineering/core": "workspace:*",
    "@harness-engineering/linter-gen": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "handlebars": "^4.7.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
