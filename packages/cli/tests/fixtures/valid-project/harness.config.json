{
  "version": 1,
  "name": "test-project",
  "layers": [
    { "name": "types", "pattern": "src/types/**", "allowedDependencies": [] },
    { "name": "domain", "pattern": "src/domain/**", "allowedDependencies": ["types"] }
  ],
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "security": {
    "enabled": true,
    "strict": false,
    "rules": { "SEC-CRY-001": "warning" },
    "exclude": ["**/coverage/**", "**/security/rules/**"]
  }
}
