{
  "name": "@harness-engineering/core",
  "version": "0.9.2",
  "description": "Core library for Harness Engineering toolkit",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/clean.mjs dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "harness",
    "engineering",
    "ai",
    "agents",
    "development"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Intense-Visions/harness-engineering.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Intense-Visions/harness-engineering/issues"
  },
  "homepage": "https://github.com/Intense-Visions/harness-engineering/tree/main/packages/core#readme",
  "dependencies": {
    "@harness-engineering/types": "workspace:*",
    "@typescript-eslint/typescript-estree": "^7.0.0",
    "glob": "^11.0.0",
    "minimatch": "^10.2.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18"
  }
}
