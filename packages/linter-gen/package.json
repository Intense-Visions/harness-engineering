{
  "name": "@harness-engineering/linter-gen",
  "version": "0.1.6",
  "description": "Generate ESLint rules from YAML configuration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/clean.mjs dist",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "handlebars": "^4.7.9",
    "minimatch": "^10.2.5",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Intense-Visions/harness-engineering.git",
    "directory": "packages/linter-gen"
  },
  "bugs": {
    "url": "https://github.com/Intense-Visions/harness-engineering/issues"
  },
  "homepage": "https://github.com/Intense-Visions/harness-engineering/tree/main/packages/linter-gen#readme"
}
