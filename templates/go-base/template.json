{
  "name": "go-base",
  "description": "Go language base scaffold with golangci-lint",
  "version": 1,
  "language": "go",
  "tooling": {
    "packageManager": "go",
    "linter": "golangci-lint",
    "formatter": "gofmt",
    "buildTool": "go",
    "testRunner": "go test"
  },
  "mergeStrategy": { "json": "deep-merge", "files": "overlay-wins" }
}
